SECRET_KEY=change-me-in-production
# Для 1000+ пользователей рекомендуется PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://cleaning:cleaning@localhost:5432/cleaning_app
DATABASE_URL=sqlite:///./app/database.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
MAX_CLEANINGS_PER_WEEK=2
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174
# Через запятую — логины с правами администратора
ADMIN_USERNAMES=Admin,Admin1
UPLOADS_DIR=uploads
MAX_AVATAR_BYTES=2097152
# Сброс пароля: 6-значный код на email (обязательно SMTP в проде)
RESET_CODE_EXPIRE_MINUTES=30
# Только если SMTP не настроен — показать код в UI (dev)
EXPOSE_RESET_TOKEN=true

# Почта (Gmail: smtp.gmail.com + пароль приложения)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=app-password
SMTP_FROM=Cleaning App <your@gmail.com>
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# SENTRY_DSN=https://...
# TELEGRAM_BOT_TOKEN=
# PUBLIC_APP_URL=http://localhost:5173
